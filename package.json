{
	"name": "iambhvsh-writing",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && pagefind --site build",
		"build:no-search": "vite build",
		"preview": "vite preview --outDir build",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "svelte-kit sync && eslint src/ --max-warnings 0",
		"lint:fix": "svelte-kit sync && eslint src/ --fix",
		"knip": "svelte-kit sync && knip",
		"format": "prettier --write src/"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@resvg/resvg-js": "^2.6.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.65.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25.9.3",
		"eslint": "^10.4.1",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"knip": "^6.16.1",
		"pagefind": "^1.5.2",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.0",
		"satori": "^0.26.0",
		"satori-html": "^0.3.2",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@lucide/svelte": "^1.17.0",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.0",
		"@vercel/analytics": "^2.0.1",
		"@vercel/speed-insights": "^2.0.0",
		"date-fns": "^4.4.0",
		"mdsvex": "^0.12.7",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-slug": "^6.0.0",
		"rehype-unwrap-images": "^1.0.0",
		"remark-toc": "^9.0.0",
		"shiki": "^4.2.0",
		"tailwindcss": "^4.3.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
